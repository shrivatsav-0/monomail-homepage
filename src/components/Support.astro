---
// Support section (UPI + Ko-fi)
---

<section class="section support-section" id="support">
  <div class="container">
    <span class="section-label">Support the project</span>
    <h2 class="section-title">Like Monomail?<br />Buy me a coffee.</h2>
    <p class="section-sub">Monomail is free, open source, and built in spare time. If it's made your inbox a little less chaotic, any support goes a long way.</p>
    <div class="support-cards">
      <!-- UPI -->
      <div class="support-card">
        <p class="support-card-label">UPI · India</p>
        <div class="upi-card-body">
          <div class="upi-qr-wrap">
            <img src="/imgs/qr-code.png" alt="UPI QR Code" />
          </div>
          <div class="upi-details">
            <p class="upi-id-label">UPI ID</p>
            <p class="upi-id">shrivatsav@slc</p>
            <a href="upi://pay?pa=shrivatsav@slc&pn=Sharan%20Shrivatsav&mode=02" class="upi-pay-btn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
              </svg>
              Pay via UPI
            </a>
          </div>
        </div>
      </div>
      <!-- KO-FI -->
      <div class="support-card">
        <p class="support-card-label">Ko-fi · International</p>
        <div class="kofi-card-body">
          <p class="kofi-card-desc">Prefer card or PayPal? Ko-fi works internationally. One coffee at a time adds up.</p>
          <a href="https://ko-fi.com/N4N2W53M5" target="_blank" class="kofi-btn-wrap">
            <img src="https://storage.ko-fi.com/cdn/kofi3.png?v=6" alt="Buy Me a Coffee at ko-fi.com" />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
